    {
      "parameters": {
        "jsCode": "// Select random music from pre-uploaded library\n// TODO: Upload music files to n8n and update paths here\nconst musicLibrary = [\n  '/data/music/energetic-1.mp3',\n  '/data/music/energetic-2.mp3',\n  '/data/music/upbeat-1.mp3',\n  '/data/music/calm-1.mp3'\n];\n\nconst strategy = $('Parse Strategy').first().json.strategy;\nconst mood = strategy.mood || 'energetic';\n\n// Filter by mood (for now just pick random)\nconst randomIndex = Math.floor(Math.random() * musicLibrary.length);\n\nreturn {\n  json: {\n    music_path: musicLibrary[randomIndex],\n    music_volume: 0.3 // Background music at 30%\n  }\n};"
      },
      "id": "select-music",
      "name": "Select Background Music",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 740]
