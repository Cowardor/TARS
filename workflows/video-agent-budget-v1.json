    {
      "parameters": {
        "jsCode": "// Assemble Shotstack JSON for video rendering\nconst strategy = $('Parse Strategy').first().json;\nconst images = $input.all().filter(item => item.json.binary?.data);\nconst voiceover = $('ElevenLabs Voiceover').first();\nconst music = $('Select Background Music').first().json;\n\n// Build clips from images\nconst imageClips = strategy.timing.map((timing, index) => ({\n  asset: {\n    type: 'image',\n    src: `data:image/png;base64,${images[index].binary.data.toString('base64')}`\n  },\n  start: timing.duration * index,\n  length: timing.duration,\n  fit: 'cover',\n  scale: 1.05, // Slight zoom for Ken Burns effect\n  transition: {\n    in: 'fade',\n    out: 'fade'\n  },\n  effect: 'zoomIn'\n}));\n\n// Calculate total duration\nconst totalDuration = strategy.timing.reduce((sum, t) => sum + t.duration, 0);\n\n// Build Shotstack timeline\nconst timeline = {\n  soundtrack: {\n    src: music.music_path,\n    effect: 'fadeInFadeOut',\n    volume: music.music_volume\n  },\n  tracks: [\n    {\n      clips: imageClips\n    },\n    {\n      clips: [\n        {\n          asset: {\n            type: 'audio',\n            src: `data:audio/mpeg;base64,${voiceover.binary.data.toString('base64')}`\n          },\n          start: 0,\n          length: totalDuration,\n          volume: 1.0\n        }\n      ]\n    }\n  ]\n};\n\n// Add text overlays if specified\nconst textClips = strategy.timing\n  .filter(t => t.text_overlay)\n  .map(timing => ({\n    asset: {\n      type: 'title',\n      text: timing.text_overlay,\n      style: 'minimal',\n      color: '#ffffff',\n      size: 'medium',\n      background: 'rgba(0,0,0,0.5)',\n      position: 'center'\n    },\n    start: timing.duration * timing.image,\n    length: 2,\n    transition: {\n      in: 'fade',\n      out: 'fade'\n    }\n  }));\n\nif (textClips.length > 0) {\n  timeline.tracks.push({ clips: textClips });\n}\n\nreturn {\n  json: {\n    timeline: timeline,\n    output: {\n      format: 'mp4',\n      resolution: '1080',\n      aspectRatio: '9:16',\n      fps: 30,\n      quality: 'high'\n    }\n  }\n};"
      },
      "id": "build-shotstack-json",
      "name": "Build Shotstack Timeline",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
