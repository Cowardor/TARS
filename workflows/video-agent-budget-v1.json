      "parameters": {
        "jsCode": "// Parse GPT response and extract strategy\nconst response = $input.first().json;\nconst content = JSON.parse(response.choices[0].message.content);\n\nreturn {\n  json: {\n    strategy: content.strategy,\n    script: content.script,\n    midjourney_prompts: content.midjourney_prompts,\n    timing: content.timing,\n    performance_estimate: content.performance_estimate,\n    // Store original product data\n    product_name: $('Extract Product Data').first().json.product_name\n  }\n};"
      },
