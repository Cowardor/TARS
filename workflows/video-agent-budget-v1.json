        "jsonBody": "={\n  \"text\": \"{{ $('Parse Strategy').first().json.script.hook }}. {{ $('Parse Strategy').first().json.script.body }}. {{ $('Parse Strategy').first().json.script.cta }}\",\n  \"model_id\": \"eleven_monolingual_v1\",\n  \"voice_settings\": {\n    \"stability\": 0.5,\n    \"similarity_boost\": 0.75,\n    \"style\": 0.3,\n    \"use_speaker_boost\": true\n  }\n}",
