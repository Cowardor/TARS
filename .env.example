# ================================
# TARS Project - Environment Variables
# ================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git!

# Groq API Key (for Voice Input — Whisper STT + llama parsing)
# Get it from: https://console.groq.com/keys (free tier: 2000 min audio/day)
GROQ_API_KEY=gsk_your-key-here

# OpenAI API Key (for GPT-4o in workflows)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# n8n API Key (for MCP server)
# Get it from: n8n Settings > API > Create API Key
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIyZGYwOTYzYy1hMzI2LTRkM2QtODBkNi1kZjIxYTBiZWFjYmQiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwiaWF0IjoxNzY5Njk0OTEyfQ.ZpRA19KfQDWVw7xCXrFdGd3Aotkk1i34vifks95yVXc

# n8n Instance URL
N8N_API_URL=http://localhost:5678

# Optional: UseAPI (Midjourney)
# Get it from: https://useapi.net/dashboard
USEAPI_KEY=your-useapi-key-here

# Optional: ElevenLabs (Voice)
# Get it from: https://elevenlabs.io/app/settings
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Optional: Shotstack (Video)
# Get it from: https://shotstack.io/dashboard
SHOTSTACK_API_KEY=your-shotstack-key-here
